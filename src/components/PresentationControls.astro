<script>
  // Presentation mode: sections become full-screen slides navigated with arrow keys
  document.addEventListener("DOMContentLoaded", () => {
    const sections = Array.from(document.querySelectorAll("main > section, main > :not(section)")).filter(
      (el) => el.tagName !== "SCRIPT"
    );

    // Group everything into "slides" — each section is a slide
    const slides = sections.filter(el => el.tagName === "SECTION" || el.id === "hero-section");
    let currentSlide = 0;

    function goToSlide(n: number) {
      currentSlide = Math.max(0, Math.min(n, slides.length - 1));
      slides[currentSlide].scrollIntoView({ behavior: "smooth", block: "start" });
      updateIndicator();
    }

    function updateIndicator() {
      const indicator = document.getElementById("slide-indicator");
      if (indicator) {
        indicator.textContent = `${currentSlide + 1} / ${slides.length}`;
      }
    }

    // Find which slide is currently visible
    function detectCurrentSlide() {
      const scrollY = window.scrollY + window.innerHeight / 3;
      for (let i = slides.length - 1; i >= 0; i--) {
        if ((slides[i] as HTMLElement).offsetTop <= scrollY) {
          currentSlide = i;
          break;
        }
      }
      updateIndicator();
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight" || e.key === "ArrowDown" || e.key === " ") {
        e.preventDefault();
        goToSlide(currentSlide + 1);
      } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
        e.preventDefault();
        goToSlide(currentSlide - 1);
      } else if (e.key === "Home") {
        e.preventDefault();
        goToSlide(0);
      } else if (e.key === "End") {
        e.preventDefault();
        goToSlide(slides.length - 1);
      }
    });

    window.addEventListener("scroll", detectCurrentSlide, { passive: true });
    updateIndicator();
  });
</script>

<!-- Slide indicator + controls -->
<div
  id="presentation-controls"
  class="fixed bottom-6 right-6 z-50 flex items-center gap-3 bg-[var(--color-graphite)]/90 backdrop-blur-sm border border-[var(--color-line)] px-4 py-2"
>
  <button
    onclick="document.dispatchEvent(new KeyboardEvent('keydown', {key: 'ArrowLeft'}))"
    class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)] text-sm transition-colors"
    aria-label="Previous slide"
  >
    ←
  </button>
  <span
    id="slide-indicator"
    class="text-[10px] tracking-[0.16em] text-[var(--color-dim)] tabular-nums min-w-[50px] text-center"
  >
    1 / ?
  </span>
  <button
    onclick="document.dispatchEvent(new KeyboardEvent('keydown', {key: 'ArrowRight'}))"
    class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)] text-sm transition-colors"
    aria-label="Next slide"
  >
    →
  </button>
</div>

<!-- Keyboard hint (fades after 3s) -->
<div
  id="keyboard-hint"
  class="fixed bottom-6 left-6 z-50 text-[10px] tracking-[0.14em] text-[var(--color-dim)] bg-[var(--color-graphite)]/90 backdrop-blur-sm border border-[var(--color-line)] px-3 py-2 transition-opacity duration-1000"
>
  ← → ARROW KEYS TO NAVIGATE ▸ SPACE TO ADVANCE
</div>

<script>
  // Fade out keyboard hint after 5 seconds
  setTimeout(() => {
    const hint = document.getElementById("keyboard-hint");
    if (hint) hint.style.opacity = "0";
    setTimeout(() => hint?.remove(), 1000);
  }, 5000);
</script>
