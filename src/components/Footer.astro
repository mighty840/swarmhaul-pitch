---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] mt-32">
  <div class="max-w-[1280px] mx-auto px-6 lg:px-8 py-12 grid grid-cols-2 md:grid-cols-5 gap-8">
    <div>
      <div class="flex items-baseline gap-2 mb-4">
        <span class="text-[14px] font-bold tracking-[0.04em]">SWARMHAUL</span>
        <span class="display-serif text-[11px] text-[var(--color-ash)]">/protocol</span>
      </div>
      <p class="text-[11px] text-[var(--color-steel)] leading-relaxed">
        Multi-agent coordination protocol on Solana.
      </p>
    </div>

    <div>
      <h3 class="label mb-3">PROTOCOL</h3>
      <ul class="space-y-2 text-[11px]">
        <li><a href="#protocol" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">How it works</a></li>
        <li><a href="#architecture" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Architecture</a></li>
        <li><a href="#security" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Security</a></li>
        <li><a href="#mcp" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">MCP integration</a></li>
      </ul>
    </div>

    <div>
      <h3 class="label mb-3">DEVELOPERS</h3>
      <ul class="space-y-2 text-[11px]">
        <li><a href="https://github.com/mighty840/swarmhaul" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">GitHub ↗</a></li>
        <li><a href="https://docs.swarmhaul.defited.com" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Docs ↗</a></li>
        <li><a href="https://github.com/mighty840/swarmhaul/issues" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Issues ↗</a></li>
      </ul>
    </div>

    <div>
      <h3 class="label mb-3">HACKATHON</h3>
      <ul class="space-y-2 text-[11px]">
        <li><a href="https://arena.colosseum.org" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Colosseum Frontier ↗</a></li>
        <li><a href="https://dashboard.swarmhaul.defited.com" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Observatory ↗</a></li>
      </ul>
    </div>

    <div>
      <h3 class="label mb-3">LEGAL</h3>
      <ul class="space-y-2 text-[11px]">
        <li><a href="https://sharang.meghsakha.com" target="_blank" rel="noreferrer" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Sharang Parnerkar ↗</a></li>
        <li><a href="/impressum" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Impressum</a></li>
        <li><a href="/privacy" class="text-[var(--color-ash)] hover:text-[var(--color-phosphor)]">Privacy Policy</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[var(--color-line)]">
    <div class="max-w-[1280px] mx-auto px-6 lg:px-8 h-10 flex items-center justify-between text-[10px] tracking-[0.14em] text-[var(--color-steel)]">
      <span>© {year} SWARMHAUL ▸ <a href="https://sharang.meghsakha.com" target="_blank" rel="noreferrer" class="hover:text-[var(--color-phosphor)]">SHARANG PARNERKAR</a> ▸ ALL RIGHTS RESERVED</span>
      <span class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-phosphor)]"></span>
        DEVNET LIVE
      </span>
    </div>
  </div>
</footer>
