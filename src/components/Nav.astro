---
const links = [
  { href: "#problem", label: "PROBLEM" },
  { href: "#protocol", label: "PROTOCOL" },
  { href: "#demo", label: "DEMO" },
  { href: "#mcp", label: "MCP" },
  { href: "#architecture", label: "ARCH" },
  { href: "#security", label: "SECURITY" },
  { href: "#team", label: "TEAM" },
  { href: "#economics", label: "ECONOMICS" },
  { href: "#why-this-wins", label: "WHY WE WIN" },
];
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-line)] bg-[var(--color-void)]/85 backdrop-blur-md"
>
  <div class="max-w-[1280px] mx-auto flex items-center justify-between px-6 lg:px-8 h-14">
    <a href="/" class="flex items-baseline gap-2 group">
      <span class="text-[16px] font-bold tracking-[0.04em] text-[var(--color-bone)] group-hover:text-[var(--color-phosphor)] transition-colors">
        SWARMHAUL
      </span>
      <span class="display-serif text-[12px] text-[var(--color-ash)]">
        /protocol
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-[10px] tracking-[0.16em] text-[var(--color-ash)] hover:text-[var(--color-phosphor)] px-3 py-2 transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/mighty840/swarmhaul"
        target="_blank"
        rel="noopener"
        class="text-[10px] tracking-[0.16em] text-[var(--color-ash)] hover:text-[var(--color-bone)] px-3 py-2"
      >
        GITHUB ↗
      </a>
      <a
        href="/swarmhaul-pitch/brandbook.html"
        class="text-[10px] tracking-[0.16em] text-[var(--color-ash)] hover:text-[var(--color-bone)] px-3 py-2"
      >
        BRAND ↗
      </a>
      <a href="https://dashboard.swarmhaul.defited.com" target="_blank" rel="noreferrer" class="btn-primary text-[10px] py-2 px-3">LAUNCH APP ↗</a>
    </div>
  </div>
</header>
