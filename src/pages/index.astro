---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PresentationControls from "../components/PresentationControls.astro";
import Hero from "../sections/Hero.astro";
import Problem from "../sections/Problem.astro";
import Protocol from "../sections/Protocol.astro";
import Demo from "../sections/Demo.astro";
import MCP from "../sections/MCP.astro";
import Architecture from "../sections/Architecture.astro";
import Security from "../sections/Security.astro";
import Roadmap from "../sections/Roadmap.astro";
import Team from "../sections/Team.astro";
import CTA from "../sections/CTA.astro";
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Problem />
    <Protocol />
    <Demo />
    <MCP />
    <Architecture />
    <Security />
    <Roadmap />
    <Team />
    <CTA />
  </main>
  <Footer />
  <PresentationControls />
</Layout>

<style>
  /* Presentation mode: each section snaps to viewport */
  main > :global(section) {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    scroll-snap-align: start;
  }

  html {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }
</style>
