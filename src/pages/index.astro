---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PresentationControls from "../components/PresentationControls.astro";
import Hero from "../sections/Hero.astro";
import Problem from "../sections/Problem.astro";
import Protocol from "../sections/Protocol.astro";
import Demo from "../sections/Demo.astro";
import MCP from "../sections/MCP.astro";
import Architecture from "../sections/Architecture.astro";
import Security from "../sections/Security.astro";
import Roadmap from "../sections/Roadmap.astro";
import Team from "../sections/Team.astro";
import Economics from "../sections/Economics.astro";
import WhyThisWins from "../sections/WhyThisWins.astro";
import CTA from "../sections/CTA.astro";
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Problem />
    <Protocol />
    <Demo />
    <MCP />
    <Architecture />
    <Security />
    <Roadmap />
    <Team />
    <Economics />
    <WhyThisWins />
    <CTA />
  </main>
  <Footer />
  <PresentationControls />
</Layout>

<style>
  /* Presentation mode: proximity snap (not mandatory — allows tall sections) */
  main > :global(section) {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    scroll-snap-align: start;
    overflow: hidden;
    position: relative;
  }

  html {
    scroll-snap-type: y proximity;
    scroll-behavior: smooth;
  }

  /* Entrance animations triggered by scroll */
  :global(.reveal) {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  :global(.reveal.visible) {
    opacity: 1;
    transform: translateY(0);
  }
  :global(.reveal-delay-1) { transition-delay: 0.1s; }
  :global(.reveal-delay-2) { transition-delay: 0.2s; }
  :global(.reveal-delay-3) { transition-delay: 0.3s; }
  :global(.reveal-delay-4) { transition-delay: 0.4s; }
</style>

<script>
  // Intersection Observer for scroll-triggered entrance animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
        }
      });
    },
    { threshold: 0.15, rootMargin: "0px 0px -60px 0px" }
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
