---
const roadmap = [
  {
    when: "WEEK 1",
    status: "shipped",
    items: [
      "Anchor program (7 ix, 3 critical audit fixes)",
      "API ⇄ Solana wired end-to-end",
      "MCP server (HTTP + stdio, 8 tools)",
      "Dashboard observatory v1",
      "Reputation system spec drafted",
    ],
  },
  {
    when: "WEEK 2",
    status: "shipped",
    items: [
      "Reputation economics layer (α, γ, Sybil ceiling)",
      "Interactive Observatory with live sliders",
      "Wallet-signed dispatch on devnet",
      "Swarm Inspector view + multi-leg map",
      "Dashboard readability overhaul",
      "O(n²) route optimizer (58ms / 1000 bids)",
      "Public deploy on Orca + devnet program",
    ],
  },
  {
    when: "WEEK 3",
    status: "in progress",
    items: [
      "✓ Multi-leg handoff auth (shipper-signed final, courier-signed handoff)",
      "✓ Agent execution loop (auto-signs intermediate confirm_leg)",
      "✓ Lifecycle timeline UI + in-transit DB mirror",
      "✓ Public MCP endpoint + Claude Desktop one-liner",
      "✓ VitePress docs site on GitHub Pages (docs.swarmhaul.defited.com queued)",
      "✓ Playwright E2E nightly suite",
      "Privy embedded wallets (remove Phantom gate)",
      "On-chain reputation PDA as DID + VC primitive",
    ],
  },
  {
    when: "WEEK 4",
    status: "planned",
    items: [
      "Agent-to-agent negotiation v1 (counter-bids on-chain)",
      "Multi-city swarm scenarios (real distances)",
      "Two-sided reputation (shippers scored too)",
      "Coordinator + agents on Turnkey / KMS (off raw JSON keypairs)",
      "3-min pitch video + Colosseum Frontier submission",
    ],
  },
  {
    when: "POST-SWARM",
    status: "north star",
    items: [
      "Mainnet deployment",
      "Mobile-first courier app",
      "Cross-chain task discovery",
      "Agent reputation export protocol",
    ],
  },
];
const statusColor: Record<string, string> = {
  shipped: "var(--color-phosphor)",
  "in progress": "var(--color-amber)",
  planned: "var(--color-cyan)",
  "north star": "var(--color-magenta)",
};
---

<section id="roadmap" class="border-t border-[var(--color-line)]">
  <div class="section">
    <div class="mb-16 max-w-3xl">
      <div class="label mb-4">▸ ROADMAP</div>
      <h2 class="text-[36px] md:text-[52px] leading-[1.05] tracking-[-0.02em] font-light">
        <span class="display-serif text-[var(--color-amber)]">Focused</span> shipping, week by week.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        roadmap.map((phase) => (
          <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-5">
            <div class="flex items-center justify-between mb-4 pb-3 border-b border-[var(--color-line)]">
              <span class="text-[12px] tracking-[0.16em] font-bold">{phase.when}</span>
              <span
                class="text-[9px] tracking-[0.14em] uppercase font-semibold"
                style={`color: ${statusColor[phase.status]}`}
              >
                ◉ {phase.status}
              </span>
            </div>
            <ul class="space-y-2">
              {phase.items.map((item) => (
                <li class="text-[11px] text-[var(--color-steel)] leading-relaxed flex gap-2">
                  <span style={`color: ${statusColor[phase.status]}`}>▸</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
