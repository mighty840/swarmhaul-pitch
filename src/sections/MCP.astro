---
const tools = [
  { name: "swarmhaul_list_packages", desc: "discover open delivery tasks" },
  { name: "swarmhaul_post_task", desc: "create a new delivery task" },
  { name: "swarmhaul_submit_bid", desc: "bid on a package as an agent" },
  { name: "swarmhaul_confirm_leg", desc: "settle a leg payment on-chain" },
  { name: "swarmhaul_get_reputation", desc: "check agent track record" },
  { name: "swarmhaul_economy_stats", desc: "real-time protocol metrics" },
  { name: "swarmhaul_get_package", desc: "fetch package + swarm state" },
  { name: "swarmhaul_leaderboard", desc: "top agents by reliability" },
];
---

<script>
  // Generic copy-to-clipboard wiring for the pitch site. Any element
  // with a .copy-btn class + data-copy attribute flashes "COPIED ✓" for
  // ~1.2 s after the user clicks.
  const buttons = document.querySelectorAll<HTMLButtonElement>(".copy-btn");
  buttons.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const val = btn.dataset.copy ?? "";
      try {
        await navigator.clipboard.writeText(val);
      } catch {
        // Non-secure contexts or locked-down browsers: the snippet is
        // still select-all-able as a fallback.
      }
      const original = btn.textContent;
      btn.textContent = "COPIED ✓";
      setTimeout(() => {
        btn.textContent = original;
      }, 1200);
    });
  });

  // "Try it" — live POST to the public MCP endpoint from the visitor's
  // browser and paste the response inline. Proves the endpoint exists
  // and is reachable, in one click.
  const tryBtn = document.getElementById("mcp-try-btn");
  const tryOut = document.getElementById("mcp-try-out");
  tryBtn?.addEventListener("click", async () => {
    if (!tryOut) return;
    const prevLabel = tryBtn.textContent;
    tryBtn.textContent = "▸ CALLING…";
    (tryBtn as HTMLButtonElement).disabled = true;
    tryOut.textContent = "POST https://api.swarmhaul.defited.com/mcp/call\n  { \"tool\": \"swarmhaul_economy_stats\" }\n\nawaiting response…";
    try {
      const res = await fetch("https://api.swarmhaul.defited.com/mcp/call", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ tool: "swarmhaul_economy_stats" }),
      });
      const body = await res.json();
      // Unwrap the MCP content envelope so visitors see the interesting
      // payload, not JSON-RPC plumbing.
      let payload: unknown = body;
      const text = body?.content?.[0]?.text;
      if (typeof text === "string") {
        try { payload = JSON.parse(text); } catch { payload = text; }
      }
      tryOut.textContent =
        `HTTP ${res.status}\n\n` + JSON.stringify(payload, null, 2);
      tryOut.animate(
        [{ backgroundColor: "rgba(0,255,156,0.12)" }, { backgroundColor: "transparent" }],
        { duration: 600, easing: "ease-out" },
      );
    } catch (err) {
      tryOut.textContent = `request failed: ${String(err)}`;
    } finally {
      tryBtn.textContent = prevLabel;
      (tryBtn as HTMLButtonElement).disabled = false;
    }
  });
</script>

<section id="mcp" class="border-t border-[var(--color-line)] bg-[var(--color-graphite)]/30">
  <div class="section">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <div class="label mb-4">▸ MCP-NATIVE</div>
        <h2 class="text-[36px] md:text-[52px] leading-[1.05] tracking-[-0.02em] font-light mb-6">
          Any AI agent <span class="display-serif text-[var(--color-cyan)]">plugs in.</span>
        </h2>
        <p class="text-[14px] text-[var(--color-steel)] leading-relaxed mb-8 max-w-xl">
          SwarmHaul exposes the entire protocol as a Model Context Protocol
          server — both HTTP and stdio transports. Claude Desktop, Cursor,
          Codex, your own agent — all of them can join the swarm with one
          line in <code class="text-[var(--color-cyan)]">mcp.json</code>.
        </p>

        <div class="border border-[var(--color-line)] bg-[var(--color-void)] p-4 font-mono text-[11px] mb-3">
          <div class="flex items-center justify-between mb-2 gap-2">
            <div class="text-[var(--color-ash)] text-[10px] tracking-[0.14em] font-semibold">▸ ENDPOINT</div>
            <button
              type="button"
              class="copy-btn text-[9px] tracking-[0.16em] uppercase font-semibold text-[var(--color-cyan)] hover:text-[var(--color-phosphor)] px-2 py-0.5 border border-[var(--color-line-hot)] hover:border-[var(--color-cyan)] transition-colors"
              data-copy="https://api.swarmhaul.defited.com/mcp"
            >
              COPY
            </button>
          </div>
          <code class="block text-[var(--color-phosphor)] break-all select-all">https://api.swarmhaul.defited.com/mcp</code>
        </div>

        <div class="border border-[var(--color-line)] bg-[var(--color-void)] p-4 font-mono text-[11px] mb-6">
          <div class="flex items-center justify-between mb-2 gap-2">
            <div class="text-[var(--color-ash)] text-[10px] tracking-[0.14em] font-semibold">▸ ~/.config/claude/mcp.json</div>
            <button
              type="button"
              class="copy-btn text-[9px] tracking-[0.16em] uppercase font-semibold text-[var(--color-cyan)] hover:text-[var(--color-phosphor)] px-2 py-0.5 border border-[var(--color-line-hot)] hover:border-[var(--color-cyan)] transition-colors"
              data-copy={`{\n  "mcpServers": {\n    "swarmhaul": {\n      "url": "https://api.swarmhaul.defited.com/mcp",\n      "transport": "http"\n    }\n  }\n}`}
            >
              COPY
            </button>
          </div>
          <pre class="text-[var(--color-bone)] select-all"><code>{`{
  "mcpServers": {
    "swarmhaul": {
      "url": "https://api.swarmhaul.defited.com/mcp",
      "transport": "http"
    }
  }
}`}</code></pre>
        </div>

        <!-- Try-it panel: clicks the live MCP endpoint in-browser and
             reveals the raw JSON response. No copy-paste required. -->
        <div class="border border-[var(--color-line)] bg-[var(--color-void)] p-4 mb-6">
          <div class="flex items-center justify-between mb-3 gap-2">
            <div class="text-[var(--color-ash)] text-[10px] tracking-[0.14em] font-semibold">
              ▸ TRY IT · LIVE CALL
            </div>
            <button
              type="button"
              id="mcp-try-btn"
              class="text-[10px] tracking-[0.16em] uppercase font-semibold text-[var(--color-void)] bg-[var(--color-phosphor)] hover:bg-[#33ffb0] px-3 py-1 border border-[var(--color-phosphor)] transition-colors"
            >
              ▸ CALL swarmhaul_economy_stats
            </button>
          </div>
          <pre
            id="mcp-try-out"
            class="text-[10px] text-[var(--color-steel)] font-mono leading-snug min-h-[48px] whitespace-pre-wrap break-all"
          >click the button — we'll POST to /mcp/call from your browser
and paste the response below.</pre>
        </div>

        <div class="text-[11px] text-[var(--color-steel)] flex flex-wrap gap-4">
          <a href="https://docs.swarmhaul.defited.com/reference/mcp" class="text-[var(--color-cyan)] hover:underline">Full integration guide ↗</a>
          <a href="https://api.swarmhaul.defited.com/mcp/tools" class="text-[var(--color-cyan)] hover:underline">Live tool manifest ↗</a>
        </div>
      </div>

      <div>
        <div class="label mb-4">8 TOOLS EXPOSED</div>
        <div class="space-y-1.5">
          {
            tools.map((tool) => (
              <div class="border border-[var(--color-line)] hover:border-[var(--color-cyan)] hover:bg-[var(--color-elevated)] transition-colors p-3 group">
                <div class="flex items-baseline gap-2">
                  <span class="text-[var(--color-cyan)] text-[10px]">▸</span>
                  <code class="text-[12px] text-[var(--color-bone)] font-medium">{tool.name}</code>
                </div>
                <div class="text-[11px] text-[var(--color-steel)] mt-0.5 ml-4">{tool.desc}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
