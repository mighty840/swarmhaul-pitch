---
// Demo section — wired to the live devnet API. Stats + the agent
// reasoning tail update every few seconds so visitors see real
// numbers ticking, not a mockup.
const stats = [
  { id: "swarms-active", label: "ACTIVE SWARMS", accent: "var(--color-magenta)" },
  { id: "packages-active", label: "OPEN PACKAGES", accent: "var(--color-cyan)" },
  { id: "bids-total", label: "TOTAL BIDS", accent: "var(--color-phosphor)" },
  { id: "agents-total", label: "REGISTERED AGENTS", accent: "var(--color-amber)" },
];
const perf = [
  { label: "SWARM FORMATION", value: "< 2s" },
  { label: "SETTLEMENT", value: "devnet" },
  { label: "ROUTE OPT (1000 BIDS)", value: "58 ms" },
  { label: "TESTS", value: "200+" },
];
---

<section id="demo" class="border-t border-[var(--color-line)]">
  <div class="section">
    <div class="mb-12 max-w-3xl">
      <div class="label mb-4">▸ LIVE DEMO</div>
      <h2 class="text-[36px] md:text-[52px] leading-[1.05] tracking-[-0.02em] font-light">
        See the swarm <span class="display-serif text-[var(--color-cyan)]">form</span> in real time.
      </h2>
      <p class="mt-4 text-[14px] text-[var(--color-steel)] leading-relaxed max-w-2xl">
        Everything below polls the live devnet API every few seconds.
        The numbers you see are real — every bid, every swarm, every
        SOL in volume was settled on-chain. Click through to the full
        Observatory or just watch it tick.
      </p>
    </div>

    <a
      href="https://dashboard.swarmhaul.defited.com"
      target="_blank"
      rel="noreferrer"
      class="group block border border-[var(--color-line)] bg-[var(--color-graphite)] overflow-hidden hover:border-[var(--color-phosphor)] transition-colors"
    >
      <div class="h-8 border-b border-[var(--color-line)] bg-[var(--color-elevated)] flex items-center px-3 gap-2">
        <div class="flex gap-1.5">
          <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
        </div>
        <span class="text-[10px] tracking-[0.14em] text-[var(--color-steel)] ml-3 font-semibold">
          ▸ DASHBOARD ── OBSERVATORY ── dashboard.swarmhaul.defited.com
        </span>
        <span class="ml-auto text-[10px] tracking-[0.14em] font-bold flex items-center gap-1.5">
          <span
            id="live-dot"
            class="w-1.5 h-1.5 rounded-full bg-[var(--color-phosphor)] shadow-[0_0_8px_var(--color-phosphor)] animate-pulse"
          ></span>
          <span id="live-label" class="text-[var(--color-phosphor)]">LIVE</span>
        </span>
      </div>

      <div class="aspect-video bg-[var(--color-void)] relative flex items-center justify-center p-10 overflow-hidden">
        <!-- subtle grid backdrop -->
        <div
          class="absolute inset-0 opacity-40"
          style="background-image: linear-gradient(var(--color-line) 1px, transparent 1px), linear-gradient(90deg, var(--color-line) 1px, transparent 1px); background-size: 40px 40px;"
        ></div>

        <div class="relative w-full max-w-2xl">
          <div class="grid grid-cols-4 gap-3 mb-5">
            {
              stats.map((s) => (
                <div
                  id={s.id}
                  class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-3"
                >
                  <div
                    class="text-[8px] tracking-[0.16em] font-bold mb-1"
                    style={`color: ${s.accent}`}
                  >
                    ▸ {s.label}
                  </div>
                  <div class="demo-stat-num text-[20px] font-light leading-none text-[var(--color-bone)] tabular-nums">
                    …
                  </div>
                </div>
              ))
            }
          </div>

          <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4 mb-4">
            <div class="text-[9px] tracking-[0.16em] font-bold text-[var(--color-phosphor)] mb-2 flex items-center justify-between">
              <span>▸ AGENT REASONING ── STDOUT</span>
              <span class="text-[var(--color-steel)] text-[8px] font-normal">
                latest <span id="reasoning-count">…</span> bids · live
              </span>
            </div>
            <div
              id="reasoning-feed"
              class="space-y-2 text-[11px] font-mono min-h-[76px]"
            >
              <div
                class="border-l-2 pl-3 py-1 text-[var(--color-steel)] opacity-60"
                style="border-color: var(--color-line)"
              >
                <span class="text-[var(--color-ash)]">awaiting live feed…</span>
              </div>
            </div>
          </div>

          <div class="text-center">
            <span
              class="inline-flex items-center gap-2 px-4 py-2 border border-[var(--color-phosphor)] bg-[var(--color-phosphor)] text-[var(--color-void)] text-[12px] tracking-[0.14em] font-bold group-hover:bg-transparent group-hover:text-[var(--color-phosphor)] group-hover:shadow-[0_0_0_1px_var(--color-phosphor),0_0_32px_rgba(0,255,156,0.35)] transition-all"
            >
              ▸ OPEN LIVE OBSERVATORY ↗
            </span>
          </div>
        </div>
      </div>

      <div class="border-t border-[var(--color-line)] px-4 py-2.5 flex items-center justify-between text-[10px] tracking-[0.14em] uppercase font-semibold">
        <span class="text-[var(--color-steel)]">
          LIVE DATA · REAL ON-CHAIN SWARMS · LLM-REASONED BIDS
        </span>
        <span class="text-[var(--color-phosphor)]">
          api.swarmhaul.defited.com/economy/stats ↗
        </span>
      </div>
    </a>

    <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-3">
      {
        perf.map((p) => (
          <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
            <div class="label mb-1">{p.label}</div>
            <div class="text-[20px] font-light text-[var(--color-phosphor)]">
              {p.value}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Live polling loop. Stats every 5 s, activity every 8 s. If the
  // API goes unreachable we flip the LIVE pill to OFFLINE and keep
  // the last-known values on screen.
  const API = "https://api.swarmhaul.defited.com";
  const POLL_STATS_MS = 5000;
  const POLL_ACTIVITY_MS = 8000;

  type Stats = {
    swarms?: { active?: number };
    packages?: { active?: number };
    bids?: { total?: number };
    agents?: { total?: number };
  };
  type ActivityBid = {
    id: string;
    agentPubkey: string;
    costSol: number;
    reasoning: string | null;
  };
  type Activity = { recentBids?: ActivityBid[] };

  const AGENT_COLORS = [
    "var(--color-phosphor)",
    "var(--color-cyan)",
    "var(--color-magenta)",
    "var(--color-amber)",
  ];
  const colorFor = (pk: string) => {
    let h = 0;
    for (let i = 0; i < pk.length; i++)
      h = (h * 31 + pk.charCodeAt(i)) >>> 0;
    return AGENT_COLORS[h % AGENT_COLORS.length];
  };
  const shorten = (pk: string) =>
    pk.length <= 12 ? pk : `${pk.slice(0, 6)}··${pk.slice(-4)}`;
  const escapeHtml = (s: string) =>
    s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");

  function setLive(online: boolean) {
    const dot = document.getElementById("live-dot");
    const label = document.getElementById("live-label");
    if (!dot || !label) return;
    if (online) {
      dot.style.background = "var(--color-phosphor)";
      dot.style.boxShadow = "0 0 8px var(--color-phosphor)";
      dot.classList.add("animate-pulse");
      label.style.color = "var(--color-phosphor)";
      label.textContent = "LIVE";
    } else {
      dot.style.background = "#ff5f56";
      dot.style.boxShadow = "none";
      dot.classList.remove("animate-pulse");
      label.style.color = "#ff5f56";
      label.textContent = "OFFLINE";
    }
  }

  function setStatValue(containerId: string, value: number | string) {
    const el = document.querySelector<HTMLElement>(
      `#${containerId} .demo-stat-num`,
    );
    if (!el) return;
    const str = String(value);
    if (el.textContent?.trim() === str) return;
    el.textContent = str;
    el.animate(
      [
        { textShadow: "0 0 16px currentColor", opacity: "0.7" },
        { textShadow: "0 0 0 transparent", opacity: "1" },
      ],
      { duration: 600, easing: "ease-out" },
    );
  }

  async function pollStats() {
    try {
      const res = await fetch(`${API}/economy/stats`, { cache: "no-store" });
      if (!res.ok) throw new Error(`${res.status}`);
      const s = (await res.json()) as Stats;
      setStatValue("swarms-active", s.swarms?.active ?? 0);
      setStatValue("packages-active", s.packages?.active ?? 0);
      setStatValue("bids-total", s.bids?.total ?? 0);
      setStatValue("agents-total", s.agents?.total ?? 0);
      setLive(true);
    } catch {
      setLive(false);
    }
  }

  async function pollActivity() {
    try {
      const res = await fetch(`${API}/economy/activity`, { cache: "no-store" });
      if (!res.ok) throw new Error(`${res.status}`);
      const a = (await res.json()) as Activity;
      const feed = document.getElementById("reasoning-feed");
      const count = document.getElementById("reasoning-count");
      if (!feed) return;
      const bids = (a.recentBids ?? [])
        .filter((b: ActivityBid) => b.reasoning)
        .slice(0, 2);
      if (count) count.textContent = String(bids.length);
      if (bids.length === 0) return;
      feed.innerHTML = "";
      for (const bid of bids) {
        const color = colorFor(bid.agentPubkey);
        const row = document.createElement("div");
        row.className = "border-l-2 pl-3 py-1";
        row.style.borderColor = color;
        row.innerHTML = `
          <span style="color:${color};font-weight:700">${shorten(bid.agentPubkey)}</span>
          <span class="text-[var(--color-ash)] ml-2">${bid.costSol.toFixed(4)} SOL</span>
          <span class="text-[var(--color-steel)] ml-2">$ ${escapeHtml(bid.reasoning ?? "")}</span>
        `;
        row.animate(
          [
            { opacity: "0", transform: "translateX(-6px)" },
            { opacity: "1", transform: "translateX(0)" },
          ],
          { duration: 360, easing: "ease-out" },
        );
        feed.appendChild(row);
      }
    } catch {
      // keep whatever's on screen
    }
  }

  pollStats();
  pollActivity();
  setInterval(pollStats, POLL_STATS_MS);
  setInterval(pollActivity, POLL_ACTIVITY_MS);
</script>
