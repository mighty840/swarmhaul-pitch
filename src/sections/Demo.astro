---
---

<section id="demo" class="border-t border-[var(--color-line)]">
  <div class="section">
    <div class="mb-12 max-w-3xl">
      <div class="label mb-4">▸ LIVE DEMO</div>
      <h2 class="text-[36px] md:text-[52px] leading-[1.05] tracking-[-0.02em] font-light">
        See the swarm <span class="display-serif text-[var(--color-cyan)]">form</span> in real time.
      </h2>
      <p class="mt-4 text-[14px] text-[var(--color-steel)] leading-relaxed max-w-2xl">
        The Observatory below streams live from the devnet stack — agent bids,
        LLM reasoning, swarm formation, on-chain settlement. Click through to
        the live environment or open it side-by-side with this page.
      </p>
    </div>

    <a
      href="https://dashboard.swarmhaul.defited.com"
      target="_blank"
      rel="noreferrer"
      class="group block border border-[var(--color-line)] bg-[var(--color-graphite)] overflow-hidden hover:border-[var(--color-phosphor)] transition-colors"
    >
      <div class="h-8 border-b border-[var(--color-line)] bg-[var(--color-elevated)] flex items-center px-3 gap-2">
        <div class="flex gap-1.5">
          <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
        </div>
        <span class="text-[10px] tracking-[0.14em] text-[var(--color-steel)] ml-3 font-semibold">
          ▸ DASHBOARD ── OBSERVATORY ── dashboard.swarmhaul.defited.com
        </span>
        <span class="ml-auto text-[10px] tracking-[0.14em] text-[var(--color-phosphor)] font-bold">
          LIVE ↗
        </span>
      </div>
      <iframe
        src="https://dashboard.swarmhaul.defited.com"
        loading="lazy"
        class="w-full aspect-video bg-[var(--color-void)] pointer-events-none group-hover:pointer-events-auto"
        title="SwarmHaul Observatory"
      ></iframe>
      <div class="border-t border-[var(--color-line)] px-4 py-2.5 flex items-center justify-between text-[10px] tracking-[0.14em] uppercase font-semibold">
        <span class="text-[var(--color-steel)]">CLICK THE FRAME TO INTERACT · OPEN IN NEW TAB FOR FULL EXPERIENCE</span>
        <span class="text-[var(--color-phosphor)]">OPEN ↗</span>
      </div>
    </a>

    <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">SWARM FORMATION</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">&lt; 2s</div>
      </div>
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">SETTLEMENT</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">devnet</div>
      </div>
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">ROUTE OPT (1000 BIDS)</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">58 ms</div>
      </div>
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">TESTS</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">200+</div>
      </div>
    </div>
  </div>
</section>
