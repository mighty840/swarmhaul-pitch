---
---

<section id="demo" class="border-t border-[var(--color-line)]">
  <div class="section">
    <div class="mb-12 max-w-3xl">
      <div class="label mb-4">▸ LIVE DEMO</div>
      <h2 class="text-[36px] md:text-[52px] leading-[1.05] tracking-[-0.02em] font-light">
        See the swarm <span class="editorial text-[var(--color-cyan)]">form</span> in real time.
      </h2>
    </div>

    <!-- Demo embed placeholder — replace with iframe to live dashboard or video -->
    <div class="relative border border-[var(--color-line)] bg-[var(--color-graphite)] overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-7 border-b border-[var(--color-line)] bg-[var(--color-elevated)] flex items-center px-3 gap-2">
        <div class="flex gap-1.5">
          <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
        </div>
        <span class="text-[9px] tracking-[0.14em] text-[var(--color-dim)] ml-3">
          ▸ DASHBOARD ── ECONOMY OBSERVATORY ── http://localhost:5173
        </span>
      </div>
      <div class="aspect-video flex items-center justify-center text-[var(--color-dim)] text-[12px] tracking-[0.16em] uppercase">
        <div class="text-center">
          <div class="mb-3 text-[var(--color-phosphor)]">▸ LOOM EMBED PLACEHOLDER</div>
          <div>Replace with &lt;iframe src=&quot;...&quot; /&gt; or screen recording</div>
        </div>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">SWARM FORMATION</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">&lt; 2s</div>
      </div>
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">SETTLEMENT</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">on-chain</div>
      </div>
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">PROTOCOL FEE</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">0%</div>
      </div>
      <div class="border border-[var(--color-line)] bg-[var(--color-graphite)] p-4">
        <div class="label mb-1">BUILT IN</div>
        <div class="text-[20px] font-light text-[var(--color-phosphor)]">21 days</div>
      </div>
    </div>
  </div>
</section>
